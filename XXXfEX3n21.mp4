<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Video Gallery</title>
    <style>
        :root {
            --bg-color: #f4f7f6;
            --card-bg-color: #ffffff;
            --text-color: #333333;
            --link-color: #007bff;
            --link-hover-color: #0056b3;
            --shadow-light: rgba(0, 0, 0, 0.08);
            --shadow-heavy: rgba(0, 0, 0, 0.15);
        }

        body {
            background-color: var(--bg-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: var(--text-color);
            text-align: center;
            padding: 0;
            margin: 0;
            line-height: 1.6;
        }

        header {
            padding: 2rem 1rem;
        }

        h1 {
            font-size: clamp(1.2rem, 5vw, 2.5rem);
            color: var(--link-color);
            margin: 0;
            text-shadow: 1px 1px 3px var(--shadow-light);
        }

        .gallery-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        figure {
            background-color: var(--card-bg-color);
            padding: 15px;
            border-radius: 12px;
            box-shadow: 0 4px 10px var(--shadow-light);
            margin: 0;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        figure:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px var(--shadow-heavy);
        }

        .img-container {
            width: 100%;
            aspect-ratio: 1 / 1;
            overflow: hidden;
            border-radius: 8px;
        }

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        figcaption {
            margin: 15px 0;
            font-size: 1rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .video-link {
            display: block;
            padding: 10px;
            background-color: var(--link-color);
            color: #ffffff;
            text-decoration: none;
            font-weight: 600;
            border-radius: 8px;
            transition: background 0.3s;
        }

        .video-link:hover {
            background-color: var(--link-hover-color);
        }

        .ad-container {
            margin: 20px auto;
            max-width: 100%;
        }

        @media (max-width: 480px) {
            .gallery-container {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
                padding: 10px;
            }
            figcaption { font-size: 0.8rem; }
        }
    </style>
</head>
<body>

    <header>
        <h1>Your Ultimate Video Gallery</h1>
    </header>

    <!-- Slot Iklan -->
    <div class="ad-container">
        <script type="text/javascript">
            atOptions = {
                'key' : '77d0d7666d4c0f56b47a00a0de655ce9',
                'format' : 'iframe',
                'height' : 60,
                'width' : 468,
                'params' : {}
            };
        </script>
        <script src="https://nailsheedlesswarn.com"></script>
    </div>

    <main class="gallery-container">
        <!-- Video 1 -->
        <figure itemscope itemtype="http://schema.org">
            <div class="img-container">
                <img src="https://github.com" alt="Behind shoes" itemprop="thumbnailUrl">
            </div>
            <figcaption itemprop="name">Behind the shoes 😂</figcaption>
            <a href="https://yusninita007.github.io" class="video-link">Watch Now</a>
        </figure>

        <!-- Video 2 -->
        <figure itemscope itemtype="http://schema.org">
            <div class="img-container">
                <img src="https://github.com" alt="In a hurry" itemprop="thumbnailUrl">
            </div>
            <figcaption itemprop="name">He's in a hurry 🏃‍♂️</figcaption>
            <a href="https://yusninita007.github.io" class="video-link">Watch Now</a>
        </figure>

        <!-- Video 3 -->
        <figure itemscope itemtype="http://schema.org">
            <div class="img-container">
                <img src="https://github.com" alt="Emotional" itemprop="thumbnailUrl">
            </div>
            <figcaption itemprop="name">I couldn't stand it 🥺</figcaption>
            <a href="https://yusninita007.github.io" class="video-link">Watch Now</a>
        </figure>

        <!-- Video 4 -->
        <figure itemscope itemtype="http://schema.org">
            <div class="img-container">
                <img src="https://github.com" alt="Ocean waves" itemprop="thumbnailUrl">
            </div>
            <figcaption itemprop="name">Look at the waves 🌊</figcaption>
            <a href="https://yusninita007.github.io" class="video-link">Watch Now</a>
        </figure>

        <!-- Video 5 -->
        <figure itemscope itemtype="http://schema.org">
            <div class="img-container">
                <img src="https://github.com" alt="Dream tutor" itemprop="thumbnailUrl">
            </div>
            <figcaption itemprop="name">Tutor i always wanted 📚</figcaption>
            <a href="https://yusninita007.github.io" class="video-link">Watch Now</a>
        </figure>

        <!-- Video 6 -->
        <figure itemscope itemtype="http://schema.org">
            <div class="img-container">
                <img src="https://github.com" alt="Tiger stripes" itemprop="thumbnailUrl">
            </div>
            <figcaption itemprop="name">Tiger stripes, fearless 🐅</figcaption>
            <a href="https://yusninita007.github.io" class="video-link">Watch Now</a>
        </figure>
    </main>

    <div style="margin: 40px 0;">
        <a href="#" class="video-link" style="display:inline-block; width: 200px;">Next Page &raquo;</a>
    </div>

</body>
</html>
